*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Environment
.env
.env.local
.env.production

# Database
*.db
*.db-journal

# Data directories
backend/data/screenshots/
backend/data/*.db

# Model weights
backend/models/*.pt
backend/models/*.onnx

# Node
node_modules/
frontend/node_modules/

# Build outputs
frontend/dist/
frontend/build/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Docker
.docker/

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml

# Pytest
.pytest_cache/

# mypy
.mypy_cache/

# Ruff
.ruff_cache/

