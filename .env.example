# ──────────────────────────────────────────────
# FireGuard AI — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and adjust values.
# Never commit the .env file to version control.
# ──────────────────────────────────────────────

# Application
FIREGUARD_ENV=development
FIREGUARD_DEBUG=true

# Server
FIREGUARD_HOST=0.0.0.0
FIREGUARD_PORT=8000

# Database (relative to backend/)
FIREGUARD_DATABASE_URL=sqlite:///./data/fireguard.db

# CORS — comma-separated origins
FIREGUARD_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Camera
FIREGUARD_CAMERA_INDEX=0
FIREGUARD_CAMERA_FPS=15

# AI Engine
FIREGUARD_MODEL_PATH=models/yolov8n_fire.pt
FIREGUARD_CONFIDENCE_THRESHOLD=0.65
FIREGUARD_DETECTION_COOLDOWN_SECONDS=30

# Storage
FIREGUARD_SCREENSHOT_DIR=data/screenshots
FIREGUARD_SCREENSHOT_QUALITY=85
FIREGUARD_SCREENSHOT_RETENTION_DAYS=90

# Alarm
FIREGUARD_ALARM_ENABLED=true
FIREGUARD_ALARM_CONFIRMATION_SECONDS=2
